# Copiar a .env.local. La app REQUIERE estas dos variables (sin ellas muestra
# "no hay datos"). Lee public.monitor_snapshot con el cliente de Supabase (anon
# key, solo lectura vía RLS) — mismo patrón que app-tareas. Son valores públicos
# y seguros; en Vercel se ponen como Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Eso es TODO lo que necesita Vercel. El botón "Actualizar" ya NO le pega al
# Lambda desde Next: invoca la RPC public.force_refresh() de Supabase, que hace
# el net.http_post al Lambda server-side. La Function URL y la api-key del Lambda
# viven solo en Supabase (supabase_cron.sql + supabase_refresh_rpc.sql), no acá.
